REVIEW_LOOP.md
plans/
.claude/

# Data & generated artifacts.
# Every CiteClaw run output (cache.db, parsed/, pdfs/, graphml, logs)
# lives under runs/ — one subdir per run, all gitignored.
runs/
scratch/
DOT_NOT_GIT/
*.db
*.log

# Office and temp files
*.pptx
*.tmp
~$*
.~lock*

# Notebook scratch (analysis notebooks etc.)
*.ipynb

# Personal configs — only configs/config.yaml (the sanitised template) is public.
# Domain-specific YAMLs (config_bio.yaml etc.) and ad-hoc test_config.yaml stay local.
configs/config_*.yaml
configs/*_config.yaml
!configs/config.yaml
